{
  "name": "shoptet-premium-readonly-mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server for Shoptet Premium API — analytics-focused tools over the private API.",
  "type": "module",
  "bin": {
    "shoptet-premium-readonly-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
